				<lv_button width="26" height="24" x="224" y="8">
					<lv_label text="X" />
					<screen_create_event screen="screen_main" anim_type="move_bottom" duration="200" />
				</lv_button>

				<lv_obj width="88" height="90" x="10" y="38" style_radius="12">
					<lv_label text="Preview" align="top_mid" y="8" />
