					</lv_button>
					<lv_button width="28" height="24" x="110" y="30">
						<lv_label text="A4" />
					</lv_button>
				</lv_obj>

				<lv_button width="106" height="30" x="14" y="132">
					<lv_label text="Cancel" />
					<screen_create_event screen="screen_main" anim_type="move_bottom" duration="200" />
				</lv_button>
				<lv_button width="106" height="30" x="138" y="132">
					<lv_label text="Confirm" />
					<screen_create_event screen="screen_main" anim_type="move_bottom" duration="200" />
				</lv_button>
			</lv_obj>
		</lv_obj>
	</view>
</screen>
